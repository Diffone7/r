            end)
            
            container.MouseLeave:Connect(function()
                Tween(container, {BackgroundColor3 = FluentUI.Theme.Tertiary}):Play()
            end)
            
            table.insert(tab.Elements, container)
            
            return {
                SetValue = function(_, value)
                    inputBox.Text = value
