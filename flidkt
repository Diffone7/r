        function tab:AddColorPicker(text, default, callback)
            local color = default or Color3.fromRGB(255, 255, 255)
            local pickerOpen = false
            
            local container = Create("Frame", {
                Name = "ColorPicker",
                Size = UDim2.new(1, 0, 0, 40),
                BackgroundColor3 = FluentUI.Theme.Tertiary,
                BorderSizePixel = 0,
                Visible = false,
                Parent = contentScroll,
            })
            
            Create("UICorner", {
                CornerRadius = UDim.new(0, 6),
                Parent = container,
            })
            
            local label = Create("TextLabel", {
                Size = UDim2.new(0.7, 0, 1, 0),
                Position = UDim2.new(0, 12, 0, 0),
                BackgroundTransparency = 1,
                Text = text,
                TextColor3 = FluentUI.Theme.Text,
                TextSize = 14,
                TextXAlignment = Enum.TextXAlignment.Left,
                Font = Enum.Font.Gotham,
                Parent = container,
            })
            
            local colorDisplay = Create("TextButton", {
                Size = UDim2.new(0, 60, 0, 28),
                Position = UDim2.new(1, -70, 0.5, -14),
                BackgroundColor3 = color,
                BorderSizePixel = 0,
                Text = "",
                AutoButtonColor = false,
                Parent = container,
            })
            
            Create("UICorner", {
                CornerRadius = UDim.new(0, 4),
                Parent = colorDisplay,
            })
            
            Create("UIStroke", {
                Color = FluentUI.Theme.Border,
                Thickness = 1,
                Parent = colorDisplay,
            })
            
            local pickerFrame = Create("Frame", {
                Size = UDim2.new(0, 0, 0, 0),
                Position = UDim2.new(0, 0, 1, 5),
                BackgroundColor3 = FluentUI.Theme.Background,
                BorderSizePixel = 0,
                ClipsDescendants = true,
                Visible = false,
                ZIndex = 10,
                Parent = container,
            })
            
            Create("UICorner", {
                CornerRadius = UDim.new(0, 6),
                Parent = pickerFrame,
            })
            
            local colorCanvas = Create("Frame", {
                Size = UDim2.new(1, -20, 1, -60),
                Position = UDim2.new(0, 10, 0, 10),
                BackgroundColor3 = Color3.fromRGB(255, 0, 0),
                BorderSizePixel = 0,
                Parent = pickerFrame,
            })
            
            Create("UICorner", {
                CornerRadius = UDim.new(0, 4),
                Parent = colorCanvas,
            })
            
            local saturationGradient = Create("UIGradient", {
                Color = ColorSequence.new{
                    ColorSequenceKeypoint.new(0, Color3.fromRGB(255, 255, 255)),
                    ColorSequenceKeypoint.new(1, Color3.fromRGB(255, 255, 255))
                },
                Transparency = NumberSequence.new{
                    NumberSequenceKeypoint.new(0, 0),
                    NumberSequenceKeypoint.new(1, 1)
                },
                Parent = colorCanvas,
            })
            
            local brightnessOverlay = Create("Frame", {
                Size = UDim2.new(1, 0, 1, 0),
                BackgroundColor3 = Color3.fromRGB(0, 0, 0),
                BorderSizePixel = 0,
                Parent = colorCanvas,
            })
            
            Create("UICorner", {
                CornerRadius = UDim.new(0, 4),
                Parent = brightnessOverlay,
            })
            
            Create("UIGradient", {
                Transparency = NumberSequence.new{
                    NumberSequenceKeypoint.new(0, 1),
                    NumberSequenceKeypoint.new(1, 0)
                },
                Rotation = 90,
                Parent = brightnessOverlay,
            })
            
            local hueSlider = Create("Frame", {
                Size = UDim2.new(1, -20, 0, 20),
                Position = UDim2.new(0, 10, 1, -40),
                BackgroundColor3 = Color3.fromRGB(255, 255, 255),
                BorderSizePixel = 0,
                Parent = pickerFrame,
            })
            
            Create("UICorner", {
                CornerRadius = UDim.new(0, 4),
                Parent = hueSlider,
            })
            
            Create("UIGradient", {
                Color = ColorSequence.new{
                    ColorSequenceKeypoint.new(0, Color3.fromRGB(255, 0, 0)),
                    ColorSequenceKeypoint.new(0.17, Color3.fromRGB(255, 255, 0)),
                    ColorSequenceKeypoint.new(0.33, Color3.fromRGB(0, 255, 0)),
                    ColorSequenceKeypoint.new(0.5, Color3.fromRGB(0, 255, 255)),
                    ColorSequenceKeypoint.new(0.67, Color3.fromRGB(0, 0, 255)),
                    ColorSequenceKeypoint.new(0.83, Color3.fromRGB(255, 0, 255)),
                    ColorSequenceKeypoint.new(1, Color3.fromRGB(255, 0, 0))
                },
                Parent = hueSlider,
            })
            
            local hueSelector = Create("Frame", {
                Size = UDim2.new(0, 4, 1, 4),
                Position = UDim2.new(0, -2, 0, -2),
                BackgroundColor3 = FluentUI.Theme.Text,
                BorderSizePixel = 0,
                Parent = hueSlider,
            })
            
            Create("UICorner", {
                CornerRadius = UDim.new(1, 0),
                Parent = hueSelector,
            })
            
            local canvasSelector = Create("Frame", {
                Size = UDim2.new(0, 12, 0, 12),
                BackgroundColor3 = Color3.fromRGB(255, 255, 255),
                BorderSizePixel = 0,
                AnchorPoint = Vector2.new(0.5, 0.5),
                Parent = colorCanvas,
            })
            
            Create("UICorner", {
                CornerRadius = UDim.new(1, 0),
                Parent = canvasSelector,
            })
            
            Create("UIStroke", {
                Color = Color3.fromRGB(0, 0, 0),
                Thickness = 2,
                Parent = canvasSelector,
            })
            
            local h, s, v = color:ToHSV()
            
            local function updateColor(newH, newS, newV)
                h, s, v = newH or h, newS or s, newV or v
                color = Color3.fromHSV(h, s, v)
                colorDisplay.BackgroundColor3 = color
                
                local hueColor = Color3.fromHSV(h, 1, 1)
                colorCanvas.BackgroundColor3 = hueColor
                
                if callback then
                    callback(color)
                end
            end
            
            local draggingCanvas = false
            local draggingHue = false
            
            colorCanvas.InputBegan:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 then
                    draggingCanvas = true
                end
            end)
            
            hueSlider.InputBegan:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 then
                    draggingHue = true
                end
            end)
            
            UserInputService.InputEnded:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 then
                    draggingCanvas = false
                    draggingHue = false
                end
            end)
            
            UserInputService.InputChanged:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseMovement then
                    if draggingCanvas then
                        local posX = math.clamp((Mouse.X - colorCanvas.AbsolutePosition.X) / colorCanvas.AbsoluteSize.X, 0, 1)
                        local posY = math.clamp((Mouse.Y - colorCanvas.AbsolutePosition.Y) / colorCanvas.AbsoluteSize.Y, 0, 1)
                        canvasSelector.Position = UDim2.new(posX, 0, posY, 0)
                        updateColor(nil, posX, 1 - posY)
                    elseif draggingHue then
                        local posX = math.clamp((Mouse.X - hueSlider.AbsolutePosition.X) / hueSlider.AbsoluteSize.X, 0, 1)
                        hueSelector.Position = UDim2.new(posX, -2, 0, -2)
                        updateColor(posX, nil, nil)
                    end
                end
            end)
            
            colorDisplay.MouseButton1Click:Connect(function()
                pickerOpen = not pickerOpen
                if pickerOpen then
                    pickerFrame.Visible = true
                    Tween(pickerFrame, {Size = UDim2.new(1, 0, 0, 200)}):Play()
                else
                    Tween(pickerFrame, {Size = UDim2.new(0, 0, 0, 0)}):Play()
                    task.wait(0.2)
                    pickerFrame.Visible = false
                end
            end)
            
            container.MouseEnter:Connect(function()
                Tween(container, {BackgroundColor3 = FluentUI.Theme.Secondary}):Play()
            end)
            
            container.MouseLeave:Connect(function()
                Tween(container, {BackgroundColor3 = FluentUI.Theme.Tertiary}):Play()
            end)
            
            table.insert(tab.Elements, container)
            
            return {
                SetValue = function(_, newColor)
                    local newH, newS, newV = newColor:ToHSV()
                    updateColor(newH, newS, newV)
                    
                    canvasSelector.Position = UDim2.new(newS, 0, 1 - newV, 0)
                    hueSelector.Position = UDim2.new(newH, -2, 0, -2)
                end,
                GetValue = function(_)
                    return color
                end
            }
        end
        
        function tab:AddKeybind(text, default, callback)
            local key = default or Enum.KeyCode.E
            local listening = false
            
            local container = Create("Frame", {
                Name = "Keybind",
                Size = UDim2.new(1, 0, 0, 40),
                BackgroundColor3 = FluentUI.Theme.Tertiary,
                BorderSizePixel = 0,
                Visible = false,
                Parent = contentScroll,
            })
            
            Create("UICorner", {
                CornerRadius = UDim.new(0, 6),
                Parent = container,
            })
            
            local label = Create("TextLabel", {
                Size = UDim2.new(0.6, 0, 1, 0),
                Position = UDim2.new(0, 12, 0, 0),
                BackgroundTransparency = 1,
                Text = text,
                TextColor3 = FluentUI.Theme.Text,
                TextSize = 14,
                TextXAlignment = Enum.TextXAlignment.Left,
                Font = Enum.Font.Gotham,
                Parent = container,
            })
            
            local keybindButton = Create("TextButton", {
                Size = UDim2.new(0, 80, 0, 28),
                Position = UDim2.new(1, -90, 0.5, -14),
                BackgroundColor3 = FluentUI.Theme.Background,
                BorderSizePixel = 0,
                Text = key.Name,
                TextColor3 = FluentUI.Theme.Text,
                TextSize = 12,
                Font = Enum.Font.GothamBold,
                AutoButtonColor = false,
                Parent = container,
            })
            
            Create("UICorner", {
                CornerRadius = UDim.new(0, 4),
                Parent = keybindButton,
            })
            
            local connection
            
            keybindButton.MouseButton1Click:Connect(function()
                listening = true
                keybindButton.Text = "..."
                Tween(keybindButton, {BackgroundColor3 = FluentUI.Theme.Accent}):Play()
                
                connection = UserInputService.InputBegan:Connect(function(input, gameProcessed)
                    if not gameProcessed and input.UserInputType == Enum.UserInputType.Keyboard then
                        listening = false
                        key = input.KeyCode
                        keybindButton.Text = key.Name
                        Tween(keybindButton, {BackgroundColor3 = FluentUI.Theme.Background}):Play()
                        connection:Disconnect()
                        
                        if callback then
                            callback(key)
                        end
                    end
                end)
            end)
            
            UserInputService.InputBegan:Connect(function(input, gameProcessed)
                if not gameProcessed and not listening and input.KeyCode == key and callback then
                    callback(key)
                end
            end)
            
            container.MouseEnter:Connect(function()
                Tween(container, {BackgroundColor3 = FluentUI.Theme.Secondary}):Play()
            end)
            
            container.MouseLeave:Connect(function()
                Tween(container, {BackgroundColor3 = FluentUI.Theme.Tertiary}):Play()
            end)
            
            table.insert(tab.Elements, container)
            
            return {
                SetValue = function(_, newKey)
                    key = newKey
                    keybindButton.Text = key.Name
                end,
                GetValue = function(_)
                    return key
                end
            }
        end
        
        table.insert(window.Tabs, tab)
        
        if #window.Tabs == 1 then
            tab:Activate()
        end
        
        return tab
    end
    
    function window:Notify(title, message, duration)
        duration = duration or 3
        
        local notification = Create("Frame", {
            Size = UDim2.new(0, 300, 0, 0),
            Position = UDim2.new(1, -310, 1, 10),
            BackgroundColor3 = FluentUI.Theme.Secondary,
            BorderSizePixel = 0,
            ClipsDescendants = true,
            Parent = screenGui,
        })
        
        Create("UICorner", {
            CornerRadius = UDim.new(0, 8),
            Parent = notification,
        })
        
        local titleLabel = Create("TextLabel", {
            Size = UDim2.new(1, -20, 0, 24),
            Position = UDim2.new(0, 10, 0, 8),
            BackgroundTransparency = 1,
            Text = title,
            TextColor3 = FluentUI.Theme.Text,
            TextSize = 14,
            TextXAlignment = Enum.TextXAlignment.Left,
            Font = Enum.Font.GothamBold,
            Parent = notification,
        })
        
        local messageLabel = Create("TextLabel", {
            Size = UDim2.new(1, -20, 0, 0),
            Position = UDim2.new(0, 10, 0, 32),
            BackgroundTransparency = 1,
            Text = message,
            TextColor3 = FluentUI.Theme.TextDim,
            TextSize = 12,
            TextXAlignment = Enum.TextXAlignment.Left,
            TextYAlignment = Enum.TextYAlignment.Top,
            Font = Enum.Font.Gotham,
            TextWrapped = true,
            AutomaticSize = Enum.AutomaticSize.Y,
            Parent = notification,
        })
        
        local totalHeight = 48 + messageLabel.AbsoluteSize.Y
        
        Tween(notification, {
            Size = UDim2.new(0, 300, 0, totalHeight),
            Position = UDim2.new(1, -310, 1, -totalHeight - 10 - (#window.Notifications * (totalHeight + 10)))
        }, 0.3):Play()
        
        table.insert(window.Notifications, notification)
        
        task.delay(duration, function()
            Tween(notification, {
                Position = UDim2.new(1, 10, notification.Position.Y.Scale, notification.Position.Y.Offset)
            }, 0.3):Play()
            
            task.wait(0.3)
            notification:Destroy()
            
            for i, notif in ipairs(window.Notifications) do
                if notif == notification then
                    table.remove(window.Notifications, i)
                    break
                end
            end
        end)
    end
    
    return window
end

return FluentUI
